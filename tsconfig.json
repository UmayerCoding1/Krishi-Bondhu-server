{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",

    "lib": ["ES2022", "DOM"],

    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "NodeNext",
    "esModuleInterop": true,

    "strict": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}